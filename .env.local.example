# Supabase — copy from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Paystack — from your Paystack dashboard
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Site URL
NEXT_PUBLIC_SITE_URL=https://urbangist.com.ng

# Admin — secret for webhook verification
WEBHOOK_SECRET=your-random-webhook-secret-here

# Supabase Storage bucket names
NEXT_PUBLIC_COVERS_BUCKET=track-covers
NEXT_PUBLIC_AUDIO_BUCKET=track-audio
